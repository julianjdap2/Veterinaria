# Copiar a .env y rellenar. No commitear .env con secretos reales.

# Obligatorias
DATABASE_URL=mysql+pymysql://usuario:password@127.0.0.1/vet_system
SECRET_KEY=cambiar-por-clave-larga-y-aleatoria

# CORS: orígenes del frontend, separados por coma (incluir puerto de Vite si el front llama directo al API)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# URL pública del frontend (enlaces en correos: «Continuar e iniciar sesión»).
# En local: misma URL que uses en el navegador con «npm run dev» (ej. http://localhost:5173).
# No uses 127.0.0.1 en correos reales a clientes: solo abre en el mismo PC con el front en marcha.
# En producción: https://tu-dominio.com
FRONTEND_PUBLIC_URL=http://localhost:5173

# Horas de validez del enlace del correo «ampliar vínculo» (parcial → completo). Por defecto 168 (7 días).
# VINCULO_INVITE_EXPIRE_HOURS=168

# JWT (opcionales; valores por defecto razonables)
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=60

# Notificaciones: log | smtp | queue
NOTIFICATION_BACKEND=log

# Si NOTIFICATION_BACKEND=smtp
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=

# Twilio (SMS/WhatsApp; opcional; sin esto el envío cae a log)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# DEFAULT_PHONE_COUNTRY_CODE=+57

# Cron: si se define, POST /cron/* requiere header X-Cron-Secret
# CRON_SECRET=

# Google reCAPTCHA v2 (registro público). Si está vacío, no se exige token en /public/registro.
# RECAPTCHA_SECRET_KEY=

# Asistente clínico (LLM, opcional OpenAI-compatible). Requiere plan con feature_ia_consultorio.
# Sin LLM_ENABLED o sin API key, solo se usan reglas locales.
# LLM_ENABLED=false
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# URL completa alternativa (p. ej. Azure OpenAI); si se define, prevalece sobre LLM_BASE_URL.
# LLM_CHAT_COMPLETIONS_URL=
# LLM_MODEL=gpt-4o-mini
# LLM_TIMEOUT_SECONDS=25
# LLM_MAX_LLM_ITEMS=6
