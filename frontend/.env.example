# Base URL de la API. En desarrollo con proxy Vite usar /api (por defecto).
# En producción apuntar al backend real, ej: https://api.midominio.com
# VITE_API_URL=/api

# Marca (landing + panel lateral)
# VITE_APP_NAME=Mi Clínica
# VITE_APP_PANEL_SUBTITLE=Consultorio

# WhatsApp flotante en landing (URL completa, ej. https://wa.me/573001234567)
# VITE_WHATSAPP_URL=

# Origen del API para resolver logos relativos (ej. http://127.0.0.1:8000). Opcional si logo_url ya es absoluta.
# VITE_BACKEND_ORIGIN=http://127.0.0.1:8000

# Google Maps JavaScript API (Places): autocomplete de ciudades en /registro. Restringir la clave por dominio y API.
# VITE_GOOGLE_MAPS_API_KEY=

# Email de contacto (muestra enlace "¿Necesitas ayuda?" en registro)
# VITE_SUPPORT_EMAIL=soporte@tudominio.com

# Google reCAPTCHA v2 (clave del sitio) — par con RECAPTCHA_SECRET_KEY en el backend
# VITE_RECAPTCHA_SITE_KEY=

# URL de términos y condiciones (enlace en el checkbox del registro)
# VITE_TERMS_URL=https://tudominio.com/terminos

# Vídeos de ayuda al entrar al panel (modal sobre el dashboard). IDs de 11 caracteres.
# Formato: Título|videoId,Título2|id2 (coma entre vídeos). Ejemplo con ID público:
# VITE_ONBOARDING_VIDEOS=Primeros pasos|jNQXAC9IVRw,Segundo tema|dQw4w9WgXcQ
